# The Odds API key — get a free key at https://the-odds-api.com
ODDS_API_KEY=your_key_here

# Redis (optional, used for caching) — leave blank to use in-memory cache
REDIS_URL=redis://localhost:6379

# How often (seconds) the background refresher polls for new odds
ODDS_REFRESH_INTERVAL=30

# Minimum arbitrage profit % to surface (e.g. 0.5 = 0.5%)
MIN_ARB_PROFIT=0.5

# App settings
HOST=0.0.0.0
PORT=8000
